generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  HR
  EMPLOYEE
}

enum ProjectType {
  WEBSITE_DEVELOPMENT
  SEO
  APP_DEVELOPMENT
  SOCIAL_MEDIA
  BRANDING
  OTHER
}

enum ProjectStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  INCOMPLETE
}

enum SalaryStatus {
  PENDING
  PAID
  PARTIAL
}

enum NotificationType {
  PROJECT_ASSIGNED
  PROJECT_COMPLETED
  PROJECT_STATUS_CHANGED
  SALARY_PAID
  DEADLINE_ALERT
  ATTENDANCE_CHECKIN
  ATTENDANCE_CHECKOUT
}

// ─── USER ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(EMPLOYEE)
  avatar       String?
  phone        String?
  designation  String?
  bio          String?
  isOnline     Boolean  @default(false)
  isFirstLogin Boolean  @default(true)
  theme        String   @default("light")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  accounts             Account[]
  sessions             Session[]
  attendance           Attendance[]          @relation("UserAttendance")
  salaries             Salary[]              @relation("UserSalary")
  assignedProjects     ProjectAssignment[]
  sentProjectMessages  ProjectMessage[]
  sentGlobalMessages   GlobalMessage[]
  notifications        Notification[]
  activityLogs         ActivityLog[]         @relation("ActorLogs")
  markedAbsences       Attendance[]          @relation("MarkedAbsentBy")
  createdSalaries      Salary[]              @relation("CreatedSalaries")
  createdProjects      Project[]             @relation("CreatedProjects")
}

// ─── NEXTAUTH TABLES ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── PROJECT ─────────────────────────────────────────────

model Project {
  id                   String        @id @default(cuid())
  title                String
  description          String?       @db.Text
  clientName           String
  clientEmail          String?
  type                 ProjectType
  status               ProjectStatus @default(ACTIVE)
  coverImage           String?
  startDate            DateTime
  dueDate              DateTime?
  progress             Int           @default(0)
  isDeadlineAlertSent  Boolean       @default(false)
  createdById          String
  createdBy            User          @relation("CreatedProjects", fields: [createdById], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  assignments  ProjectAssignment[]
  messages     ProjectMessage[]
  credentials  WebDevCredentials?
}

model ProjectAssignment {
  id         String   @id @default(cuid())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  assignedAt DateTime @default(now())

  @@unique([projectId, userId])
}

model WebDevCredentials {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String   @unique
  devUrl    String
  username  String
  password  String
  notes     String?  @db.Text
  updatedAt DateTime @updatedAt
}

model ProjectMessage {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  content   String   @db.Text
  mediaUrl  String?
  createdAt DateTime @default(now())
}

// ─── GLOBAL CHAT ─────────────────────────────────────────

model GlobalMessage {
  id        String   @id @default(cuid())
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  content   String   @db.Text
  mediaUrl  String?
  createdAt DateTime @default(now())
}

// ─── ATTENDANCE ──────────────────────────────────────────

model Attendance {
  id               String           @id @default(cuid())
  user             User             @relation("UserAttendance", fields: [userId], references: [id])
  userId           String
  date             DateTime         @db.Date
  checkIn          DateTime?
  checkOut         DateTime?
  workHours        Float?
  status           AttendanceStatus @default(PRESENT)
  markedAbsentById String?
  markedAbsentBy   User?            @relation("MarkedAbsentBy", fields: [markedAbsentById], references: [id])
  note             String?
  createdAt        DateTime         @default(now())

  @@unique([userId, date])
}

// ─── SALARY ──────────────────────────────────────────────

model Salary {
  id          String       @id @default(cuid())
  user        User         @relation("UserSalary", fields: [userId], references: [id])
  userId      String
  month       String
  amount      Float
  status      SalaryStatus @default(PENDING)
  paidAt      DateTime?
  note        String?
  createdById String
  createdBy   User         @relation("CreatedSalaries", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, month])
}

// ─── NOTIFICATIONS ────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

// ─── ACTIVITY LOG ─────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  actor      User     @relation("ActorLogs", fields: [actorId], references: [id])
  actorId    String
  actorName  String
  actorRole  Role
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}
